  "flow_environment": {
    "symbol": "Phi",
    "declared_type_is_immutable": true,
    "facts": ["remaining closed-union alternative identities", "finite R0 refinement facts", "enum case identity", "usable-place state"],
    "true_edge": "add only facts proved by the current structural partition and admitted inline R0 guard",
    "false_edge": "retain the complement only when the finite partition engine proves it",
    "join": "intersection of facts true on every incoming edge",
    "kill": ["assignment to the subject or an aliased place", "exclusive borrow", "escape or capture with possible mutation", "call whose responsibility summary may mutate or consume the subject"],
