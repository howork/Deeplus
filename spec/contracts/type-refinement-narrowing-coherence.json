  },
  "rules": [
    {
      "rule_id": "TRN-R001",
      "title": "narrowing changes flow facts, not the declared semantic type",
      "contract": "Normalize the declared domain once; an arm-local type is the declared domain intersected with Phi and structural coverage. No branch rewrites the declaration."
    },
    {
      "rule_id": "TRN-R002",
      "title": "closed-union typed arm has one bounded elaboration",
      "contract": "Inside a match-like refutable context whose subject is a normalized closed union, Identifier : TypeRef elaborates to UnionAlternativeBindPattern only when TypeRef is exactly one declared alternative identity. It performs UNION_INJECTION_TAG_TEST and binds that alternative. Everywhere else it remains the irrefutable static TypedBindPattern."
    },
    {
      "rule_id": "TRN-R003",
      "title": "union alternative selection is not an open runtime type test",
      "contract": "The test reads only the discriminator of the already-declared closed union. Subtyping search, reflection, provider lookup, Trait witness discovery, arbitrary downcast and refinement-predicate execution are forbidden."
    },
    {
      "rule_id": "TRN-R004",
      "title": "union formation requires a finite disjoint relation",
      "contract": "After flattening and exact deduplication, every alternative pair must be proven DISJOINT by the finite R0 relation engine. EQUIVALENT or IMPLIES emits UNION_MEMBER_SUBSUMED; OVERLAPS or UNKNOWN rejects formation without inventing a runtime choice."
    },
    {
      "rule_id": "TRN-R005",
      "title": "refinement proof is required at every narrowing boundary",
      "contract": "At construction, typed pattern, argument, return, and explicit cast boundaries, PROVED admits, DISPROVED emits the exact literal/range diagnostic, and UNKNOWN emits REFINEMENT_PROOF_REQUIRED. A boundary-free conversion emits REFINEMENT_IMPLICIT_NARROWING_FORBIDDEN."
    },
    {
      "rule_id": "TRN-R006",
      "title": "refinement operations have distinct outcomes",
      "contract": "as? produces Option<T>; as! produces T with the declared failed-cast defect edge; T::check produces Result<T, error E>. None erases proof obligations or manufactures a Phi fact before success."
    },
    {
      "rule_id": "TRN-R007",
      "title": "def#guard is pure Bool but opaque for narrowing",
      "contract": "A def#guard callable must be total, pure, terminating, nonsuspending, nonconsuming, authority-free and return exactly Bool. Until a separate canonical summary surface and API digest exist, a call to it creates no refinement or union fact."
    },
    {
      "rule_id": "TRN-R008",
      "title": "inline guards refine only an admitted structural partition",
      "contract": "A guard runs after structural probe and before ownership commit. Only an inline finite R0 predicate may refine the true-edge Phi; a false guard commits no binding, move, borrow or authority."
    },
    {
      "rule_id": "TRN-R009",
      "title": "guarded arms are useful but never total coverage",
      "contract": "Usefulness is checked against the structural partition, but guarded arms do not subtract from the exhaustiveness residual. A residual covered only by guarded arms emits MATCH_NONEXHAUSTIVE_AFTER_GUARDS."
    },
    {
      "rule_id": "TRN-R010",
      "title": "match usefulness and exhaustiveness are one ordered pass",
      "contract": "For each arm compute structural coverage, diagnose an empty new set as MATCH_ARM_UNREACHABLE, subtract only unguarded coverage, diagnose otherwise after empty residual as OTHERWISE_UNREACHABLE, then emit MATCH_NOT_EXHAUSTIVE for a remaining witness."
    },
    {
      "rule_id": "TRN-R011",
      "title": "enum patterns resolve identity and payload before a guard",
      "contract": "Resolve the VariantId in the subject Enum owner, then validate active payload arity, labels/positions and child pattern types. Unknown or foreign cases and inactive payload projections reject before guard evaluation and commit."
    },
    {
      "rule_id": "TRN-R012",
      "title": "or-pattern binders and ownership state must agree",
      "contract": "Every alternative binds the same names with identical canonical type, mode, mutability, usable lifetime and capability. Projection path and source-field order may differ. Normally returning arms must join to the same usable-place state."
    },
    {
      "rule_id": "TRN-R013",
      "title": "probe and commit are transactional",
      "contract": "Structural failure, an unreachable pattern, or a false guard produces zero committed bindings, moves, exclusive borrows and authorities; successful admission commits the precomputed plan atomically once."
    }
  ],
  "diagnostic_order": [
    "pattern syntax and owner admission",
    "closed-union or enum identity",
