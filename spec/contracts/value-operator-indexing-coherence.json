      "rule_id": "VOI-R001",
      "domain": "value_identity",
      "title": "source value identity is independent of representation identities",
      "contract": {
        "source_semantic_identity": "normalized source type and value",
        "independent_domains": [
          "storage layout",
          "serialization tag",
          "runtime discriminant",
          "foreign ABI identity",
          "backend lowering identity"
        ],
        "source_equivalence_implies_equal_layout": false,
        "layout_equivalence_implies_source_equivalence": false,
        "abi_or_layout_selected_by_contract": false
      }
    },
    {
      "rule_id": "VOI-R002",
      "domain": "integer_values",
      "title": "integer domains and failure behavior are explicit",
      "contract": {
        "unsuffixed_integer_normalization": "Int",
        "numeric_token_contains_sign": false,
        "sign_ast_owner": "PrefixExpr",
        "contextual_prefix_sign_adapter": {
          "required_ast_shape": "PrefixExpr(-, UnsuffixedIntegerLiteral)",
          "required_context": "one independently fixed exact Int, IntN, or UIntN target",
          "candidate": "negative of the validated token magnitude",
          "admission": "signed candidate is mathematically representable in the exact target",
          "ISize_or_USize_target": false,
          "arbitrary_constant_folding": false,
          "hidden_widening_or_narrowing": false,
          "list_out_of_range_diagnostic": "LIST_LITERAL_CONTEXT_INTEGER_OUT_OF_RANGE"
        },
        "Int_mathematical_domain": "-9223372036854775808..9223372036854775807",
        "explicit_domains": [
          "Int8",
          "Int16",
          "Int32",
          "Int64",
          "Int128",
          "UInt8",
          "UInt16",
          "UInt32",
          "UInt64",
          "UInt128",
          "ISize",
          "USize"
        ],
        "static_overflow": "REJECT",
        "dynamic_overflow": "DETERMINISTIC_DEFECT_BEFORE_COMMIT",
        "divide_or_remainder_by_zero": "DETERMINISTIC_DEFECT_BEFORE_COMMIT",
        "implicit_wrap": false,
        "implicit_saturate": false,
        "named_wrap_or_saturate_api_required": true
      }
    },
    {
      "rule_id": "VOI-R003",
      "domain": "floating_values",
      "title": "floating behavior is bounded to IEEE binary values",
      "contract": {
        "Float32": "IEEE-754 binary32",
        "Float64": "IEEE-754 binary64",
