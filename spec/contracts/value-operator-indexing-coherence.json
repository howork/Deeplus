    {
      "rule_id": "VOI-R006",
      "domain": "numeric_operator_typing",
      "title": "homogeneous scalar operators use one exact normalized domain and specialized owners delegate",
      "contract": {
        "literal_context_adaptation": "a signless unsuffixed integer may adopt an exact representable Int/IntN/UIntN target; only direct PrefixExpr(-, UnsuffixedIntegerLiteral) may instead adapt its signed -magnitude candidate; no arbitrary folding; ISize/USize require suffix or checked conversion; unsuffixed float remains Float64",
        "homogeneous_scalar_operators": ["+", "-", "*", "/", "%", "integer ^"],
        "homogeneous_scalar_operand_domain_count": 1,
        "specialized_intrinsic_routes": {
          "Measure ^ StaticInt": "measure_static_power_law",
          "NumericArray ** or *+": "shape-specific linear algebra law",
          "NumericArray infix ^": "PREVIEW_NONACTIVATABLE_WITHOUT_GATE"
        },
        "implicit_widening": false,
        "implicit_narrowing": false,
        "mixed_signedness_dispatch": false,
        "mixed_width_dispatch": false,
        "result_domain": "the exact homogeneous scalar domain, or the separately specified closed intrinsic result for a specialized owner",
        "user_conformance_can_change_result": false
      }
    },
