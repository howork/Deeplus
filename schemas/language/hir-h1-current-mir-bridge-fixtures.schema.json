{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deeplus-lang.org/schema/r51f3/hir-h1-current-mir-bridge-fixtures-r1.json",
  "title": "Deeplus HIR-H1 current-MIR bridge design fixtures",
  "type": "object",
  "additionalProperties": false,
  "required": [
