    },
    "source_activation": {
      "const": "none"
    },
    "semantic_p0": {
      "const": 0
    },
    "current_binding": {
      "const": false
    },
    "open_feature_p1": {
      "const": [
        "CE-C-P1-001",
        "CE-C-P1-002",
        "CE-C-P1-003",
        "CE-C-P1-004",
        "CE-C-P1-005",
        "CE-C-P1-006",
        "CE-E-P1-001",
        "CE-E-P1-002",
        "CE-E-P1-003",
        "CE-E-P1-004",
        "CE-E-P1-005",
        "CE-E-P1-006",
        "CE-E-P1-007",
        "CE-E-P1-008",
        "TCC-P1-002",
        "TCC-P1-003",
        "TCC-P1-004",
        "TCC-P1-005",
        "TCC-P1-006",
        "TCC-P1-007",
        "TCC-P1-008",
        "SFD-P1-009"
      ]
    },
    "product_lanes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rust_frontend_lexer",
        "rust_frontend_parser",
        "rust_hir_lowering",
        "rust_integrated_checker",
        "deeplus_mir_lowering",
        "xvm_bytecode_emitter",
        "xvm_interpreter",
        "llvm_aot_backend",
