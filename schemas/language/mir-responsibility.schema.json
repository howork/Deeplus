{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deeplus-lang.org/schema/r51f3/mir-responsibility.schema.json",
  "title": "Deeplus R51f3 MIR responsibility record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "law_id",
    "source_order",
    "evaluation_events",
    "temporary_stack",
    "ownership_events",
    "commit_point",
    "cleanup_stack",
    "rollback_stack",
    "primary_failure",
    "suppressed_failures",
    "cancellation_state",
    "task_scope",
    "actor_isolation",
    "control_events",
    "callable_events",
    "evidence_events",
    "effect_row",
    "authority",
    "source_span"
  ],
  "properties": {
    "law_id": {
      "type": "string",
      "pattern": "^OP-[A-Z]+(?:-[A-Z]+)*-[0-9]{3}$"
    },
    "source_order": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "evaluation_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evaluateEvent"
      }
    },
    "temporary_stack": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/temporary_acquireEvent"
      }
    },
    "ownership_events": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/ownership_borrowEvent"
          },
          {
            "$ref": "#/$defs/ownership_moveEvent"
          },
          {
            "$ref": "#/$defs/ownership_commitEvent"
          }
        ]
      }
    },
    "commit_point": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "cleanup_stack": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/cleanupEvent"
      }
    },
    "rollback_stack": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rollbackEvent"
      }
    },
    "primary_failure": {
      "oneOf": [
        {
          "$ref": "#/$defs/failureEvent"
        },
        {
          "type": "null"
        }
      ]
    },
    "suppressed_failures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/suppressed_failureEvent"
      }
    },
    "cancellation_state": {
      "oneOf": [
        {
          "$ref": "#/$defs/cancellation_requestEvent"
        },
        {
          "type": "null"
        }
      ]
    },
    "task_scope": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/task_spawnEvent"
          },
          {
            "$ref": "#/$defs/task_joinEvent"
          }
        ]
      }
    },
    "actor_isolation": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/actor_enqueueEvent"
          },
          {
            "$ref": "#/$defs/actor_dequeueEvent"
          }
        ]
      }
    },
    "control_events": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/guardEvent"
          },
          {
            "$ref": "#/$defs/payloadEvent"
          },
          {
            "$ref": "#/$defs/loop_handlerEvent"
          }
        ]
      }
    },
    "callable_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/callable_invokeEvent"
      }
    },
    "evidence_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_selectEvent"
      }
    },
    "effect_row": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "authority": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "source_span": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file",
        "start",
        "end"
      ],
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1
        },
        "start": {
          "type": "integer",
          "minimum": 0
        },
        "end": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
