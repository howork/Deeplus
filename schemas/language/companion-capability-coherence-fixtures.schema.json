        {
          "contains": {
            "type": "object",
            "required": [
              "fixture_class"
            ],
            "properties": {
              "fixture_class": {
                "const": "negative"
              }
            }
          },
          "minContains": 7,
          "maxContains": 7
        },
        {
          "contains": {
            "type": "object",
            "required": [
              "fixture_class"
            ],
            "properties": {
              "fixture_class": {
                "const": "boundary"
              }
            }
          },
          "minContains": 7,
          "maxContains": 7
