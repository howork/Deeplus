    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_id",
        "fixture_class",
        "rule_ids",
        "facet",
        "source_or_scenario",
        "expected_design",
        "diagnostic_family_or_null",
        "assertions",
        "oracle",
        "p1_delta",
        "execution_state",
        "product_support",
        "product_receipt"
      ],
      "properties": {
        "fixture_id": {
          "type": "string",
          "pattern": "^CCC-R1-(POS|NEG|BOUND|MUT)-[0-9]{3}$"
        },
        "fixture_class": {
          "enum": [
            "positive",
            "negative",
            "boundary",
            "mutation"
          ]
        },
        "rule_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^CCC-R0(0[1-9]|1[0-8])$"
          }
        },
        "facet": {
          "enum": [
            "SURFACE",
            "LOOKUP",
            "KIND",
            "IDENTITY",
            "AUTHORITY",
            "VALUE_STATE",
            "RUNTIME_STATE",
            "ACTIVATION",
            "ORDERING",
            "EVIDENCE"
          ]
        },
        "source_or_scenario": {
          "type": "string",
          "minLength": 1
        },
        "expected_design": {
          "enum": [
            "ACCEPT",
            "REJECT",
            "BOUNDARY",
            "MUTANT_KILLED"
          ]
        },
        "diagnostic_family_or_null": {
          "type": [
            "string",
            "null"
          ]
        },
        "assertions": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "oracle": {
          "$ref": "#/$defs/oracle"
        },
        "p1_delta": {
          "const": 0
        },
        "execution_state": {
          "const": "DESIGN_STATIC_NOT_RUN"
        },
        "product_support": {
          "const": "NOT_RUN"
        },
        "product_receipt": {
          "const": null
        }
      }
    },
