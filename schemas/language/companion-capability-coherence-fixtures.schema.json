          "TCC-P1-005",
          "TCC-P1-006",
          "TCC-P1-007",
          "TCC-P1-008",
          "SFD-P1-009"
        ]
      }
    },
    "p1_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "closed",
        "created"
      ],
      "properties": {
        "closed": {
          "const": 0
        },
        "created": {
          "const": 0
        }
      }
    },
    "product_lanes": {
      "$ref": "#/$defs/productLanes"
    },
    "cases": {
      "type": "array",
      "minItems": 28,
      "maxItems": 28,
      "items": {
        "$ref": "#/$defs/case"
