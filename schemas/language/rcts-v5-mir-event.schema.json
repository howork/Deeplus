        "facet_dispatch_call",
        "facet_view_release",
        "bitfield_materialize_begin",
        "bitfield_field_eval",
        "bitfield_range_check",
        "bitfield_insert",
        "bitfield_materialize_commit",
        "bitfield_raw_decode_begin",
        "bitfield_reserved_mask_check",
        "bitfield_derive_begin",
        "bitfield_flags_op",
