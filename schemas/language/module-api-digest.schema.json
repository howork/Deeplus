{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deeplus-lang.org/schema/r51f3/module-api-digest.schema.json",
  "title": "Deeplus R51f3 normalized module API digest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "baseline",
    "module_id",
    "source_role",
    "symbols",
    "canonical_sha256"
  ],
  "properties": {
    "schema": {
      "const": "deeplus.module-api-digest/r51f3"
    },
    "baseline": {
      "const": "0.1.2-baseline.r51f3"
    },
    "module_id": {
      "type": "string",
      "minLength": 1,
      "description": "Resolved (PackageId, ModulePath) identity; never inferred from the filesystem path alone."
    },
    "source_role": {
      "enum": [
        "library",
        "executable"
      ]
    },
    "symbols": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "symbol_id",
          "kind",
          "normalized_signature",
          "responsibility_profile",
          "ownership",
          "cleanup",
          "error_set",
          "effect_row",
          "cancellation",
          "suspends",
          "authority",
          "isolation",
          "evidence_ids"
        ],
        "properties": {
          "symbol_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "enum": [
              "type",
              "function",
              "method",
              "conformance",
              "static_binding"
            ]
          },
          "normalized_signature": {
            "type": "string",
            "minLength": 1
          },
          "responsibility_profile": {
            "$ref": "#/$defs/responsibilityProfile"
          },
          "ownership": {
            "enum": [
              "not_applicable",
              "reusable",
              "borrow",
              "inout",
              "move",
              "resource"
            ]
          },
          "cleanup": {
            "enum": [
              "not_applicable",
              "none",
              "view_release",
              "drop_exactly_once"
            ]
          },
          "callable_profile": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "lifetime",
              "call_right",
              "environment_receiver",
              "behavior"
            ],
            "properties": {
              "lifetime": {
                "enum": [
                  "escaping",
                  "scoped"
                ]
              },
              "call_right": {
                "enum": [
                  "repeatable",
                  "once"
                ]
              },
              "environment_receiver": {
                "enum": [
                  "shared",
                  "mutable"
                ]
              },
              "behavior": {
                "enum": [
                  "ordinary",
                  "pure",
                  "guard"
                ]
              }
            }
          },
          "named_rest_residue": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "const": "Record***"
              }
            ]
          },
          "error_set": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "effect_row": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "cancellation": {
            "enum": [
              "not_applicable",
              "forbidden",
              "propagate",
              "observe",
              "shielded_cleanup"
            ]
          },
          "suspends": {
            "oneOf": [
              {"type": "boolean"},
              {"const": "not_applicable"}
            ]
          },
          "authority": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "isolation": {
            "enum": [
              "not_applicable",
              "local",
              "task",
              "actor",
              "global"
            ]
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "construction_row_sha256": {
            "oneOf": [
              {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              {
                "type": "null"
              }
            ]
          },
          "projection_row_sha256": {
            "oneOf": [
              {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              {
                "type": "null"
              }
            ]
          },
          "function_static_activation": {
            "oneOf": [
              {
                "$ref": "#/$defs/functionStaticActivationResidue"
              },
              {
                "type": "null"
              }
            ]
          },
          "fixed_operator_conformance": {
            "oneOf": [
              {
                "$ref": "#/$defs/fixedOperatorConformanceResidue"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "type"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "construction_row_sha256",
                "projection_row_sha256"
              ],
              "not": {
                "anyOf": [
                  {
                    "required": [
                      "callable_profile"
                    ]
                  },
                  {
                    "required": [
                      "named_rest_residue"
                    ]
                  },
                  {
                    "required": [
                      "function_static_activation"
                    ]
                  }
                ]
              },
              "properties": {
                "responsibility_profile": {
                  "properties": {"profile_kind": {"const": "type"}},
                  "required": ["profile_kind"]
                },
                "ownership": {"const": "not_applicable"},
                "cleanup": {"const": "not_applicable"},
                "cancellation": {"const": "not_applicable"},
                "suspends": {"const": "not_applicable"},
                "isolation": {"const": "not_applicable"}
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "function"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "callable_profile",
                "named_rest_residue"
              ],
              "not": {
                "anyOf": [
                  {
                    "required": [
                      "construction_row_sha256"
                    ]
                  },
                  {
                    "required": [
                      "projection_row_sha256"
                    ]
                  }
                ]
              },
              "properties": {
                "responsibility_profile": {
                  "properties": {"profile_kind": {"const": "callable"}},
                  "required": ["profile_kind"]
                },
                "ownership": {"const": "not_applicable"},
                "cleanup": {"const": "not_applicable"},
                "cancellation": {
                  "enum": ["forbidden", "propagate", "observe", "shielded_cleanup"]
                },
                "suspends": {"type": "boolean"},
                "isolation": {
                  "enum": ["local", "task", "actor", "global"]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "method"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "callable_profile",
                "named_rest_residue"
              ],
              "not": {
                "anyOf": [
                  {
                    "required": [
                      "construction_row_sha256"
                    ]
                  },
                  {
                    "required": [
                      "projection_row_sha256"
                    ]
                  }
                ]
              },
              "properties": {
                "responsibility_profile": {
                  "properties": {"profile_kind": {"const": "callable"}},
                  "required": ["profile_kind"]
                },
                "ownership": {"const": "not_applicable"},
                "cleanup": {"const": "not_applicable"},
                "cancellation": {
                  "enum": ["forbidden", "propagate", "observe", "shielded_cleanup"]
                },
                "suspends": {"type": "boolean"},
                "isolation": {
                  "enum": ["local", "task", "actor", "global"]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "conformance"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [],
              "not": {
                "anyOf": [
                  {
                    "required": [
                      "callable_profile"
                    ]
                  },
                  {
                    "required": [
                      "named_rest_residue"
                    ]
                  },
                  {
                    "required": [
                      "construction_row_sha256"
                    ]
                  },
                  {
                    "required": [
                      "projection_row_sha256"
                    ]
                  },
                  {
                    "required": [
                      "function_static_activation"
                    ]
                  }
                ]
              },
              "properties": {
                "responsibility_profile": {
                  "properties": {"profile_kind": {"const": "conformance"}},
                  "required": ["profile_kind"]
                },
                "ownership": {"const": "not_applicable"},
                "cleanup": {"const": "not_applicable"},
                "cancellation": {"const": "not_applicable"},
                "suspends": {"const": "not_applicable"},
                "isolation": {"const": "not_applicable"},
                "evidence_ids": {
                  "minItems": 1
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "static_binding"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [],
              "not": {
                "anyOf": [
                  {
                    "required": [
                      "callable_profile"
                    ]
                  },
                  {
                    "required": [
                      "named_rest_residue"
                    ]
                  },
                  {
                    "required": [
                      "construction_row_sha256"
                    ]
                  },
                  {
                    "required": [
                      "projection_row_sha256"
                    ]
                  },
                  {
                    "required": [
                      "function_static_activation"
                    ]
                  }
                ]
              },
              "properties": {
                "responsibility_profile": {
                  "properties": {"profile_kind": {"const": "static_binding"}},
                  "required": ["profile_kind"]
                },
                "ownership": {"const": "not_applicable"},
                "cleanup": {"const": "not_applicable"},
                "cancellation": {"const": "not_applicable"},
                "suspends": {"const": "not_applicable"},
                "isolation": {"const": "not_applicable"}
              }
            }
          },
          {
            "if": {
              "required": [
                "function_static_activation"
              ],
              "properties": {
                "function_static_activation": {
                  "type": "object"
                }
              }
            },
            "then": {
              "properties": {
                "kind": {
                  "enum": [
                    "function",
                    "method"
                  ]
                },
                "callable_profile": {
                  "properties": {
                    "behavior": {
                      "enum": [
                        "ordinary",
                        "pure"
                      ]
                    }
                  },
                  "required": [
                    "behavior"
                  ]
                },
                "cancellation": {
                  "const": "forbidden"
                },
                "suspends": {
                  "const": false
                }
              }
            }
          },
          {
            "if": {
              "required": [
                "fixed_operator_conformance"
              ],
              "properties": {
                "fixed_operator_conformance": {
                  "type": "object"
                }
              }
            },
            "then": {
              "properties": {
                "kind": {
                  "const": "conformance"
                }
              }
            }
          }
        ]
      }
    },
    "canonical_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "fixedOperatorConformanceResidue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator_id",
        "normalized_left_type_id",
        "normalized_right_type_id",
        "conformance_id",
        "witness_id",
        "method_id",
        "substitution_id",
        "output_type_id",
        "responsibility_profile_id",
        "dispatch_route",
        "runtime_relookup_count",
        "fallback_count"
      ],
      "properties": {
        "operator_id": {
          "enum": ["BinaryAdd", "BinarySubtract", "BinaryMultiply"]
        },
        "normalized_left_type_id": {"type": "string", "minLength": 1},
        "normalized_right_type_id": {"type": "string", "minLength": 1},
        "conformance_id": {"type": "string", "minLength": 1},
        "witness_id": {"type": "string", "minLength": 1},
        "method_id": {"type": "string", "minLength": 1},
        "substitution_id": {"type": "string", "minLength": 1},
        "output_type_id": {"type": "string", "minLength": 1},
        "responsibility_profile_id": {
          "const": "BORROWED_PURE_TOTAL_SYNCHRONOUS_NONCONSUMING"
        },
        "dispatch_route": {"const": "DIRECT_GLOBAL"},
        "runtime_relookup_count": {"const": 0},
        "fallback_count": {"const": 0}
      }
    },
    "responsibilityChannel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel_id", "type_identity", "ownership", "cleanup"],
      "properties": {
        "channel_id": {"type": "string", "minLength": 1},
        "type_identity": {"type": "string", "minLength": 1},
        "visible_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "call_channel_kind": {
          "enum": [
            "receiver",
            "value",
            "context",
            "witness",
            "repeated_positional",
            "named_rest",
            "trailing_closure",
            "result",
            "capture"
          ]
        },
        "ownership": {
          "enum": ["reusable", "borrow", "inout", "move", "resource"]
        },
        "cleanup": {
          "enum": ["none", "view_release", "drop_exactly_once"]
        },
        "task_origin": {
          "enum": [
            "ordinary_async",
            "actor_request_admitted"
          ]
        },
        "task_responsibility": {
          "$ref": "#/$defs/taskResponsibilityDescriptor"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type_identity": {
                "pattern": "(?:^|[^A-Za-z0-9_])Task<"
              }
            },
            "required": [
              "type_identity"
            ]
          },
          "then": {
            "required": [
              "task_origin"
            ]
          },
          "else": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "task_origin"
                  ]
                },
                {
                  "required": [
                    "task_responsibility"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "task_origin": {
                "const": "actor_request_admitted"
              }
            },
            "required": [
              "task_origin"
            ]
          },
          "then": {
            "required": [
              "task_responsibility"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "task_origin": {
                "const": "ordinary_async"
              }
            },
            "required": [
              "task_origin"
            ]
          },
          "then": {
            "not": {
              "required": [
                "task_responsibility"
              ]
            }
          }
        }
      ]
    },
    "taskResponsibilityDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_type",
        "normalized_handler_error_set",
        "cancellation_axis",
        "isolation_owner",
        "correlation_id",
        "terminal_transport_failure"
      ],
      "properties": {
        "result_type": {
          "type": "string",
          "minLength": 1
        },
        "normalized_handler_error_set": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "not": {
              "enum": [
                "mailboxFull",
                "receiverClosedBeforeAdmission",
                "ActorMessageError::mailboxFull",
                "ActorMessageError::receiverClosedBeforeAdmission"
              ]
            }
          },
          "uniqueItems": true
        },
        "cancellation_axis": {
          "type": "string",
          "minLength": 1
        },
        "isolation_owner": {
          "type": "string",
          "minLength": 1
        },
        "correlation_id": {
          "const": "per_value_non_forgeable"
        },
        "terminal_transport_failure": {
          "type": "array",
          "items": {
            "const": "receiverClosedBeforeReply"
          },
          "minItems": 1,
          "maxItems": 1,
          "uniqueItems": true
        }
      }
    },
    "functionStaticActivationHelperDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "callable_implementation_id",
        "activation_present",
        "safety_summary_sha256"
      ],
      "properties": {
        "callable_implementation_id": {
          "type": "string",
          "minLength": 1
        },
        "activation_present": {
          "const": false
        },
        "safety_summary_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "functionStaticActivationResidue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activation_present",
        "activation_semantics_version",
        "callable_implementation_id",
        "owner_recipe_profile",
        "owner_recipe_sha256",
        "activation_contract_sha256",
        "safety_summary_sha256",
        "dependency_digest_sha256",
        "used_witness_ids",
        "used_conformance_ids",
        "helper_dependencies",
        "failure_profile",
        "publication_profile"
      ],
      "properties": {
        "activation_present": {
          "const": true
        },
        "activation_semantics_version": {
          "const": "function-static-activation/r1"
        },
        "callable_implementation_id": {
          "type": "string",
          "minLength": 1
        },
        "owner_recipe_profile": {
          "const": "CallableImplementationId+normalized_instantiation+activation_contract_digest/v1"
        },
        "owner_recipe_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "activation_contract_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "safety_summary_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "dependency_digest_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "used_witness_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "used_conformance_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "helper_dependencies": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/functionStaticActivationHelperDependency"
          }
        },
        "failure_profile": {
          "const": "terminal_cached_uniform_failure_no_retry_v1"
        },
        "publication_profile": {
          "const": "owner_terminal_state_happens_before_observer_v1"
        }
      }
    },
    "responsibilityProfile": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["profile_kind", "declaration_ownership"],
          "properties": {
            "profile_kind": {"const": "type"},
            "declaration_ownership": {"const": "not_applicable"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["profile_kind", "receiver", "parameters", "result", "captures"],
          "properties": {
            "profile_kind": {"const": "callable"},
            "receiver": {
              "oneOf": [
                {"$ref": "#/$defs/responsibilityChannel"},
                {"type": "null"}
              ]
            },
            "parameters": {
              "type": "array",
              "items": {"$ref": "#/$defs/responsibilityChannel"}
            },
            "result": {"$ref": "#/$defs/responsibilityChannel"},
            "captures": {
              "type": "array",
              "items": {"$ref": "#/$defs/responsibilityChannel"}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["profile_kind", "evidence_ownership", "evidence_cleanup"],
          "properties": {
            "profile_kind": {"const": "conformance"},
            "evidence_ownership": {"const": "reusable"},
            "evidence_cleanup": {"const": "none"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["profile_kind", "value"],
          "properties": {
            "profile_kind": {"const": "static_binding"},
            "value": {"$ref": "#/$defs/responsibilityChannel"}
          }
        }
      ]
    }
  },
  "x-deeplus-symbol-id-contract": {
    "identity_key": "symbol_id",
    "uniqueness": "all symbol_id values are pairwise distinct; duplicate IDs are rejected even when the remaining symbol payload differs",
    "ordering": "strict ascending Unicode scalar sequence order by symbol_id",
    "duplicate_error": "MODULE_API_SYMBOL_ID_DUPLICATE",
    "order_error": "MODULE_API_SYMBOL_ID_ORDER"
  },
  "x-deeplus-kind-field-contracts": {
    "type": {
      "required": [
        "construction_row_sha256",
        "projection_row_sha256"
      ],
      "forbidden": [
        "callable_profile",
        "named_rest_residue",
        "function_static_activation",
        "fixed_operator_conformance"
      ]
    },
    "function": {
      "required": [
        "callable_profile",
        "named_rest_residue"
      ],
      "forbidden": [
        "construction_row_sha256",
        "projection_row_sha256",
        "fixed_operator_conformance"
      ],
      "optional": [
        "function_static_activation"
      ],
      "concrete_responsibility_axes": [
        "cancellation",
        "suspends",
        "isolation"
      ]
    },
    "method": {
      "required": [
        "callable_profile",
        "named_rest_residue"
      ],
      "forbidden": [
        "construction_row_sha256",
        "projection_row_sha256",
        "fixed_operator_conformance"
      ],
      "optional": [
        "function_static_activation"
      ],
      "concrete_responsibility_axes": [
        "cancellation",
        "suspends",
        "isolation"
      ]
    },
    "conformance": {
      "required": [],
      "forbidden": [
        "callable_profile",
        "named_rest_residue",
        "construction_row_sha256",
        "projection_row_sha256",
        "function_static_activation"
      ],
      "optional": [
        "fixed_operator_conformance"
      ],
      "nonempty": [
        "evidence_ids"
      ]
    },
    "static_binding": {
      "required": [],
      "forbidden": [
        "callable_profile",
        "named_rest_residue",
        "construction_row_sha256",
        "projection_row_sha256",
        "function_static_activation",
        "fixed_operator_conformance"
      ]
    }
  },
  "x-deeplus-function-static-activation-contract": {
    "absence": "an absent or null function_static_activation field means activation_present=false; existing callable canonical bytes need not add a null member",
    "presence_owner": "only kind=function or kind=method with synchronous, cancellation-forbidden ordinary or pure callable profile",
    "identity_domain": "CallableImplementationId is semantic and target-independent; FunctionStaticOwnerId is computed per normalized instantiation and is not a machine address",
    "runtime_key": "(RuntimeInstanceId, FunctionStaticOwnerId)",
    "recipe_collision": "equal FunctionStaticOwnerId with unequal canonical owner recipes is a terminal link error",
    "sorted_unique_rows": [
      "used_witness_ids",
      "used_conformance_ids",
      "helper_dependencies by callable_implementation_id"
    ],
