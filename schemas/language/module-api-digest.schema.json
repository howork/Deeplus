{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deeplus-lang.org/schema/r51f3/module-api-digest.schema.json",
  "title": "Deeplus R51f3 normalized module API digest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "baseline",
    "module_id",
    "source_role",
    "symbols",
    "canonical_sha256"
  ],
  "properties": {
    "schema": {
      "const": "deeplus.module-api-digest/r51f3"
    },
    "baseline": {
      "const": "0.1.2-baseline.r51f3"
    },
    "module_id": {
      "type": "string",
      "minLength": 1
    },
    "source_role": {
      "enum": [
        "library",
        "executable"
      ]
    },
    "symbols": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "symbol_id",
          "kind",
          "normalized_signature",
          "responsibility_profile",
          "ownership",
          "cleanup",
          "error_set",
          "effect_row",
          "cancellation",
          "suspends",
          "authority",
          "isolation",
          "evidence_ids"
        ],
        "properties": {
          "symbol_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "enum": [
              "type",
              "function",
              "method",
              "conformance",
              "static_binding"
            ]
          },
          "normalized_signature": {
            "type": "string",
            "minLength": 1
          },
          "responsibility_profile": {
            "$ref": "#/$defs/responsibilityProfile"
          },
          "ownership": {
            "enum": [
              "not_applicable",
              "reusable",
              "borrow",
              "inout",
              "move",
              "resource"
            ]
          },
          "cleanup": {
            "enum": [
              "not_applicable",
              "none",
              "view_release",
              "drop_exactly_once"
            ]
          },
          "callable_profile": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "lifetime",
              "call_right",
              "environment_receiver",
              "behavior"
            ],
            "properties": {
              "lifetime": {
                "enum": [
                  "escaping",
                  "scoped"
                ]
              },
              "call_right": {
                "enum": [
                  "repeatable",
                  "once"
                ]
              },
              "environment_receiver": {
                "enum": [
                  "shared",
                  "mutable"
                ]
              },
              "behavior": {
                "enum": [
                  "ordinary",
                  "pure",
                  "guard"
                ]
              }
            }
          },
          "named_rest_residue": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "const": "Record***"
              }
            ]
          },
          "error_set": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "effect_row": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "cancellation": {
            "enum": [
              "not_applicable",
              "forbidden",
              "propagate",
              "observe",
              "shielded_cleanup"
            ]
          },
          "suspends": {
            "oneOf": [
              {"type": "boolean"},
              {"const": "not_applicable"}
            ]
          },
          "authority": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "isolation": {
            "enum": [
              "not_applicable",
              "local",
              "task",
              "actor",
              "global"
            ]
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "construction_row_sha256": {
            "oneOf": [
              {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              {
                "type": "null"
              }
            ]
          },
          "projection_row_sha256": {
            "oneOf": [
              {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "type"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "construction_row_sha256",
                "projection_row_sha256"
              ],
              "not": {
                "anyOf": [
                  {
                    "required": [
                      "callable_profile"
                    ]
                  },
                  {
                    "required": [
                      "named_rest_residue"
                    ]
                  }
                ]
              },
              "properties": {
                "responsibility_profile": {
                  "properties": {"profile_kind": {"const": "type"}},
                  "required": ["profile_kind"]
                },
                "ownership": {"const": "not_applicable"},
                "cleanup": {"const": "not_applicable"},
                "cancellation": {"const": "not_applicable"},
                "suspends": {"const": "not_applicable"},
                "isolation": {"const": "not_applicable"}
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "function"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "callable_profile",
                "named_rest_residue"
              ],
              "not": {
                "anyOf": [
                  {
                    "required": [
                      "construction_row_sha256"
                    ]
                  },
                  {
                    "required": [
                      "projection_row_sha256"
                    ]
                  }
                ]
              },
              "properties": {
                "responsibility_profile": {
                  "properties": {"profile_kind": {"const": "callable"}},
                  "required": ["profile_kind"]
                },
                "ownership": {"const": "not_applicable"},
                "cleanup": {"const": "not_applicable"},
                "cancellation": {
                  "enum": ["forbidden", "propagate", "observe", "shielded_cleanup"]
                },
                "suspends": {"type": "boolean"},
                "isolation": {
                  "enum": ["local", "task", "actor", "global"]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "method"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "callable_profile",
                "named_rest_residue"
              ],
              "not": {
                "anyOf": [
                  {
                    "required": [
                      "construction_row_sha256"
                    ]
                  },
                  {
                    "required": [
                      "projection_row_sha256"
                    ]
                  }
                ]
              },
              "properties": {
                "responsibility_profile": {
                  "properties": {"profile_kind": {"const": "callable"}},
                  "required": ["profile_kind"]
                },
                "ownership": {"const": "not_applicable"},
                "cleanup": {"const": "not_applicable"},
                "cancellation": {
                  "enum": ["forbidden", "propagate", "observe", "shielded_cleanup"]
                },
                "suspends": {"type": "boolean"},
                "isolation": {
                  "enum": ["local", "task", "actor", "global"]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "conformance"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [],
              "not": {
                "anyOf": [
                  {
                    "required": [
                      "callable_profile"
                    ]
                  },
                  {
                    "required": [
                      "named_rest_residue"
                    ]
                  },
                  {
                    "required": [
                      "construction_row_sha256"
                    ]
                  },
                  {
                    "required": [
                      "projection_row_sha256"
                    ]
                  }
                ]
              },
              "properties": {
                "responsibility_profile": {
                  "properties": {"profile_kind": {"const": "conformance"}},
                  "required": ["profile_kind"]
                },
                "ownership": {"const": "not_applicable"},
                "cleanup": {"const": "not_applicable"},
                "cancellation": {"const": "not_applicable"},
                "suspends": {"const": "not_applicable"},
                "isolation": {"const": "not_applicable"},
                "evidence_ids": {
                  "minItems": 1
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "static_binding"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [],
              "not": {
                "anyOf": [
                  {
                    "required": [
                      "callable_profile"
                    ]
                  },
                  {
                    "required": [
                      "named_rest_residue"
                    ]
                  },
                  {
                    "required": [
                      "construction_row_sha256"
                    ]
                  },
                  {
                    "required": [
                      "projection_row_sha256"
                    ]
                  }
                ]
              },
              "properties": {
                "responsibility_profile": {
                  "properties": {"profile_kind": {"const": "static_binding"}},
                  "required": ["profile_kind"]
                },
                "ownership": {"const": "not_applicable"},
                "cleanup": {"const": "not_applicable"},
                "cancellation": {"const": "not_applicable"},
                "suspends": {"const": "not_applicable"},
                "isolation": {"const": "not_applicable"}
              }
            }
          }
        ]
      }
    },
    "canonical_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "responsibilityChannel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel_id", "type_identity", "ownership", "cleanup"],
      "properties": {
        "channel_id": {"type": "string", "minLength": 1},
        "type_identity": {"type": "string", "minLength": 1},
        "ownership": {
          "enum": ["reusable", "borrow", "inout", "move", "resource"]
        },
        "cleanup": {
          "enum": ["none", "view_release", "drop_exactly_once"]
        }
      }
    },
    "responsibilityProfile": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["profile_kind", "declaration_ownership"],
          "properties": {
            "profile_kind": {"const": "type"},
            "declaration_ownership": {"const": "not_applicable"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["profile_kind", "receiver", "parameters", "result", "captures"],
          "properties": {
            "profile_kind": {"const": "callable"},
            "receiver": {
              "oneOf": [
                {"$ref": "#/$defs/responsibilityChannel"},
                {"type": "null"}
              ]
            },
            "parameters": {
              "type": "array",
              "items": {"$ref": "#/$defs/responsibilityChannel"}
            },
            "result": {"$ref": "#/$defs/responsibilityChannel"},
            "captures": {
              "type": "array",
              "items": {"$ref": "#/$defs/responsibilityChannel"}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["profile_kind", "evidence_ownership", "evidence_cleanup"],
          "properties": {
            "profile_kind": {"const": "conformance"},
            "evidence_ownership": {"const": "reusable"},
            "evidence_cleanup": {"const": "none"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["profile_kind", "value"],
          "properties": {
            "profile_kind": {"const": "static_binding"},
            "value": {"$ref": "#/$defs/responsibilityChannel"}
          }
        }
      ]
    }
  },
  "x-deeplus-symbol-id-contract": {
    "identity_key": "symbol_id",
    "uniqueness": "all symbol_id values are pairwise distinct; duplicate IDs are rejected even when the remaining symbol payload differs",
    "ordering": "strict ascending Unicode scalar sequence order by symbol_id",
    "duplicate_error": "MODULE_API_SYMBOL_ID_DUPLICATE",
    "order_error": "MODULE_API_SYMBOL_ID_ORDER"
  },
  "x-deeplus-kind-field-contracts": {
    "type": {
      "required": [
        "construction_row_sha256",
        "projection_row_sha256"
      ],
      "forbidden": [
        "callable_profile",
        "named_rest_residue"
      ]
    },
    "function": {
      "required": [
        "callable_profile",
        "named_rest_residue"
      ],
      "forbidden": [
        "construction_row_sha256",
        "projection_row_sha256"
      ],
      "concrete_responsibility_axes": [
        "cancellation",
        "suspends",
        "isolation"
      ]
    },
    "method": {
      "required": [
        "callable_profile",
        "named_rest_residue"
      ],
      "forbidden": [
        "construction_row_sha256",
        "projection_row_sha256"
      ],
      "concrete_responsibility_axes": [
        "cancellation",
        "suspends",
        "isolation"
      ]
    },
    "conformance": {
      "required": [],
      "forbidden": [
        "callable_profile",
        "named_rest_residue",
        "construction_row_sha256",
        "projection_row_sha256"
      ],
      "nonempty": [
        "evidence_ids"
      ]
    },
    "static_binding": {
      "required": [],
      "forbidden": [
        "callable_profile",
        "named_rest_residue",
        "construction_row_sha256",
        "projection_row_sha256"
      ]
    }
  },
  "x-deeplus-callable-channel-id-contract": {
    "scope": "for each function or method, collect every non-null receiver channel plus every parameters, result, and captures channel",
    "identity_key": "channel_id",
    "uniqueness": "all collected channel_id values are pairwise distinct across the complete callable responsibility profile",
    "duplicate_error": "MODULE_API_CALLABLE_CHANNEL_ID_DUPLICATE"
  },
  "x-deeplus-canonical-byte-algorithm": {
    "hash_algorithm": "SHA-256",
    "excluded_top_level_fields": [
      "canonical_sha256"
    ],
    "precondition": "validate the closed schema, kind-field contracts, pairwise symbol_id uniqueness, strict symbol order, and sorted unique set-like rows before hashing",
    "symbol_order": "strict ascending Unicode scalar sequence by symbol_id",
    "set_like_fields": [
      "authority",
      "effect_row",
      "error_set",
      "evidence_ids"
    ],
    "set_order": "strict ascending Unicode scalar sequence with no duplicates",
    "object_member_order": "ascending Unicode scalar sequence by member name at every object depth",
    "string_encoding": "emit JSON mandatory escapes for quotation mark, reverse solidus, and U+0000..U+001F; emit every other Unicode scalar directly as UTF-8 without normalization",
    "whitespace": "none outside string values",
    "terminal_newline": false,
    "steps": [
      "deep-copy the validated digest object",
      "remove exactly the top-level canonical_sha256 member",
      "sort symbols by symbol_id and each declared set-like row by Unicode scalar sequence",
      "serialize object members in Unicode-scalar key order using comma and colon separators without spaces",
      "encode the resulting JSON text as UTF-8 and SHA-256 those bytes"
    ]
  },
  "x-deeplus-fixture-registry": "tests/fixtures/imported/module-api-digest-fixtures.json",
  "x-product-compiler": "NOT_RUN"
}
