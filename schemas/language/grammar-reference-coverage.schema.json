              "properties": {
                "row_count": {
                  "const": 1341
                },
                "unique_id_count": {
                  "const": 1341
                }
              }
            }
          ]
        },
        "predicates": {
          "allOf": [
            {
              "$ref": "#/$defs/registryBinding"
            },
            {
              "properties": {
                "row_count": {
                  "const": 250
                },
                "unique_id_count": {
                  "const": 250
                }
              }
            }
          ]
        },
        "prelude": {
          "allOf": [
            {
              "$ref": "#/$defs/registryBinding"
            },
            {
              "properties": {
                "row_count": {
                  "const": 63
                },
                "unique_id_count": {
                  "const": 63
                }
              }
            }
          ]
        },
        "examples": {
          "allOf": [
            {
              "$ref": "#/$defs/registryBinding"
            },
            {
              "properties": {
                "row_count": {
                  "const": 716
                },
                "unique_id_count": {
                  "const": 716
                }
              }
            }
          ]
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_path",
        "semantic_p0",
        "feature_p1_status",
        "feature_p1_ids",
        "separate_action_status",
        "separate_open_action_ids",
        "product_lanes"
