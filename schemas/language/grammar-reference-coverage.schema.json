{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deeplus-lang.org/schema/r51f3/grammar-reference-coverage-r1.json",
  "title": "Deeplus grammar reference coverage manifest R1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "revision",
    "reference_root",
    "authority",
    "source_bindings",
    "manual_documents",
    "generated_outputs",
    "grammar",
    "registries",
    "governance",
    "manual_quality",
    "vocabulary",
    "coverage",
    "product_support"
  ],
  "properties": {
    "schema": {
      "const": "deeplus.grammar-reference-coverage/r1"
    },
    "revision": {
      "const": "r51f3-current-exact-numeric-hir-h1-coherence-r1"
    },
    "reference_root": {
      "const": "docs/grammar-reference"
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "semantic_authority",
        "conflict_order"
      ],
      "properties": {
        "kind": {
          "const": "CANONICAL_DOCUMENTATION_PROJECTION"
        },
        "semantic_authority": {
          "const": false
        },
        "conflict_order": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fileBinding"
      }
    },
    "manual_documents": {
      "type": "array",
      "minItems": 26,
      "maxItems": 26,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "path",
          "title",
          "status_marker",
          "bytes",
          "sha256"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(landing|[0-9]{2})$"
          },
          "path": {
            "type": "string",
            "pattern": "^docs/grammar-reference/.+\\.md$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status_marker": {
            "const": "CURRENT_CANONICAL_DOCUMENTATION_PROJECTION"
          },
          "bytes": {
            "type": "integer",
            "minimum": 1
          },
          "sha256": {
            "$ref": "#/$defs/sha256"
          }
        }
      }
    },
    "generated_outputs": {
      "type": "array",
      "minItems": 7,
      "items": {
        "$ref": "#/$defs/fileBinding"
      }
    },
    "grammar": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "production_count",
        "profile_counts",
        "duplicate_production_count",
        "unknown_profile_count"
      ],
      "properties": {
        "path": {
          "const": "spec/grammar/deeplus.ebnf"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "production_count": {
          "const": 573
        },
        "profile_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "LEXICAL",
            "STABLE",
            "PREVIEW",
            "RECOVERY"
          ],
          "properties": {
            "LEXICAL": {
              "const": 91
            },
            "STABLE": {
              "const": 454
            },
            "PREVIEW": {
              "const": 13
            },
            "RECOVERY": {
              "const": 15
            }
          }
        },
        "duplicate_production_count": {
          "const": 0
        },
        "unknown_profile_count": {
          "const": 0
        }
      }
    },
    "registries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "features",
        "diagnostics",
        "predicates",
        "prelude",
        "examples"
      ],
      "properties": {
        "features": {
          "allOf": [
            {
              "$ref": "#/$defs/registryBinding"
            },
            {
              "properties": {
                "row_count": {
                  "const": 694
