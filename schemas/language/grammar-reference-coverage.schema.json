        "status_fence_scope": {
          "const": "UNTIL_NEXT_FENCE_OR_EOF"
        },
        "status_fence_violation_count": {
          "const": 0
        }
      }
    },
    "vocabulary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "hard_keyword_count",
        "contextual_word_count"
