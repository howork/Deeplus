        "unknown_reference_count": {
          "const": 0
        },
        "status_fence_violations": {
          "const": 0
        }
      }
    },
    "product_support": {
      "const": "NOT_RUN"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "fileBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "bytes",
        "sha256"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
