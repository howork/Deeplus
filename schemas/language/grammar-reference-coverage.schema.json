          }
        },
        "separate_action_status": {
          "const": "OPEN"
        },
        "separate_open_action_ids": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "M13-A002",
              "M13-A003",
              "M13-A004",
              "M13-A005"
            ]
          }
        },
        "product_lanes": {
          "$ref": "#/$defs/productLanes"
        }
