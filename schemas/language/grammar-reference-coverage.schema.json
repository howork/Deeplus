            "enum": [
              "CE-C-P1-001",
              "CE-C-P1-002",
              "CE-C-P1-003",
              "CE-C-P1-004",
              "CE-C-P1-005",
              "CE-C-P1-006",
              "CE-E-P1-001",
              "CE-E-P1-002",
              "CE-E-P1-003",
              "CE-E-P1-004",
              "CE-E-P1-005",
              "CE-E-P1-006",
              "CE-E-P1-007",
              "CE-E-P1-008",
              "TCC-P1-002",
              "TCC-P1-003",
              "TCC-P1-004",
              "TCC-P1-005",
              "TCC-P1-006",
              "TCC-P1-007",
              "TCC-P1-008",
              "SFD-P1-009"
