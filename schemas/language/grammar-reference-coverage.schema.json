        },
        "hard_keyword_count": {
          "const": 30
        },
        "contextual_word_count": {
          "const": 101
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targets",
        "observed",
        "uncovered_count",
        "unknown_reference_count",
        "status_fence_violations"
      ],
      "properties": {
        "targets": {
