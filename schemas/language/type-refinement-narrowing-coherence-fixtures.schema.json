{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deeplus-lang.org/schema/r51f3/type-refinement-narrowing-coherence-fixtures.schema.json",
  "title": "Deeplus type refinement, narrowing, guard, enum, and match coherence fixtures",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "fixture_schema", "revision", "contract", "semantic_p0", "current_binding", "open_feature_p1", "product_lanes", "cases", "expected_counts"],
  "properties": {
    "schema": {"const": "deeplus.type-refinement-narrowing-coherence-fixtures/r1"},
    "fixture_schema": {"const": "schemas/language/type-refinement-narrowing-coherence-fixtures.schema.json"},
    "revision": {"const": "r51f3-current-literal-shaped-collection-design-r1"},
    "contract": {"const": "spec/contracts/type-refinement-narrowing-coherence.json"},
    "semantic_p0": {"const": 0},
    "current_binding": {"const": false},
    "open_feature_p1": {"type": "array", "minItems": 22, "maxItems": 22, "uniqueItems": true, "items": {"type": "string"}},
    "product_lanes": {"type": "object", "minProperties": 15, "maxProperties": 15, "additionalProperties": {"const": "NOT_RUN"}},
    "cases": {"type": "array", "minItems": 40, "maxItems": 40, "uniqueItems": true, "items": {"$ref": "#/$defs/case"}},
    "expected_counts": {
      "type": "object", "additionalProperties": false,
      "required": ["cases", "admit", "reject", "runtime_union_pattern_tests", "closed_union_expression_tests", "open_runtime_type_tests", "def_guard_narrowing_facts", "p1_closed", "p1_created"],
      "properties": {
        "cases": {"const": 40}, "admit": {"const": 13}, "reject": {"const": 27},
        "runtime_union_pattern_tests": {"const": 2}, "closed_union_expression_tests": {"const": 5}, "open_runtime_type_tests": {"const": 0},
        "def_guard_narrowing_facts": {"const": 0}, "p1_closed": {"const": 0}, "p1_created": {"const": 0}
      }
    }
  },
  "$defs": {
    "case": {
      "type": "object", "additionalProperties": false,
      "required": ["fixture_id", "rule_ids", "subject", "pattern_or_boundary", "proof_state", "guard_origin", "expected", "diagnostic_or_null", "flow_in", "flow_true", "flow_false", "flow_join", "commit_count"],
      "properties": {
        "fixture_id": {"type": "string", "pattern": "^TRN-R1-(POS|NEG|BOUND)-[0-9]{3}$"},
        "rule_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"pattern": "^TRN-R[0-9]{3}$"}},
        "subject": {"type": "string", "minLength": 1},
        "pattern_or_boundary": {"type": "string", "minLength": 1},
        "proof_state": {"enum": ["PROVED", "DISPROVED", "UNKNOWN", "NOT_APPLICABLE"]},
        "guard_origin": {"enum": ["NONE", "INLINE_R0", "DEF_GUARD_OPAQUE"]},
        "expected": {"enum": ["ADMIT", "REJECT"]},
        "diagnostic_or_null": {"type": ["string", "null"]},
        "flow_in": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "flow_true": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "flow_false": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "flow_join": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "commit_count": {"type": "integer", "minimum": 0, "maximum": 1}
      }
    }
  }
}
