        "fixture_id",
        "fixture_class",
        "rule_ids",
        "domain",
        "source",
        "subject_profile",
        "expected",
        "diagnostic_or_null",
        "assertions",
        "execution_state"
      ],
      "properties": {
        "fixture_id": {
          "type": "string",
          "pattern": "^VOI-R1-(POS|NEG|BND)-[0-9]{3}$"
        },
        "fixture_class": {
          "enum": ["positive", "negative", "boundary"]
        },
        "rule_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^VOI-R0(0[1-9]|1[0-2])$"
          }
        },
        "domain": {
          "enum": [
            "value",
            "literal",
            "operator",
            "assignment",
            "range",
            "index",
            "slice",
            "trait_guard",
            "evidence_boundary"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "subject_profile": {
          "type": "string",
          "minLength": 1
        },
        "expected": {
          "enum": ["ADMIT", "REJECT", "WARN"]
        },
        "diagnostic_or_null": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9_]+$"
            },
            {
              "type": "null"
            }
          ]
        },
        "assertions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "array",
              "object",
              "null"
            ]
          }
        },
        "execution_state": {
          "const": "DESIGN_STATIC_NOT_RUN"
