{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deeplus.example/schemas/current-pointer-v1.json",
  "title": "Deeplus Current Pointer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "updated_at",
    "language_version",
    "spec_revision",
    "source_revision",
    "authority_digest",
    "product_lanes",
    "open_actions"
  ],
  "properties": {
    "schema": {"const": "deeplus.current-pointer/v1"},
    "updated_at": {"type": "string", "format": "date-time"},
    "language_version": {"type": "string"},
    "spec_revision": {"type": "string"},
    "source_revision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": {"enum": ["git-commit", "git-tag", "legacy-import"]},
        "value": {"type": "string", "minLength": 1},
        "repository": {"type": ["string", "null"]}
      }
    },
    "authority_digest": {"type": "string", "minLength": 1},
    "source_snapshot": {
      "type": ["object", "null"],
      "properties": {
        "library_file_id": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "required": ["library_file_id", "sha256"],
      "additionalProperties": false
    },
    "product_lanes": {
      "type": "object",
      "additionalProperties": {
        "enum": [
          "NOT_RUN",
          "BLOCKED",
          "FAILED",
          "PASSED_FOCUSED",
          "PASSED_INTEGRATED",
          "PASSED_INDEPENDENT"
        ]
      }
    },
    "open_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "priority", "summary", "owner"],
        "properties": {
          "id": {"type": "string"},
          "priority": {"enum": ["P0", "P1", "P2"]},
          "summary": {"type": "string"},
          "owner": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "required_next_reviews": {
      "type": "array",
      "items": {"type": "string"}
    },
    "previous_pointer": {"type": ["string", "null"]}
  }
}

