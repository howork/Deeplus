{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deeplus.example/schemas/current-pointer-v2.json",
  "title": "Deeplus Current Pointer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "updated_at",
    "language_version",
    "spec_revision",
    "publication_authority_source",
    "audited_implementation_baseline",
    "candidate_binding",
    "authority_digest",
    "product_lanes",
    "open_actions"
  ],
  "properties": {
    "schema": {"const": "deeplus.current-pointer/v2"},
    "updated_at": {"type": "string", "format": "date-time"},
    "language_version": {"type": "string"},
    "spec_revision": {"type": "string"},
    "publication_authority_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "commit", "role", "repository"],
      "properties": {
        "kind": {"const": "git-commit"},
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "role": {"const": "publication_authority_source"},
        "repository": {"type": "string", "minLength": 1}
      }
    },
    "audited_implementation_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "commit", "repository", "branch", "role"],
      "properties": {
        "kind": {"const": "git-commit"},
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "repository": {"type": "string", "minLength": 1},
        "branch": {"const": "main"},
        "role": {"const": "document_consistency_repair_base"}
      }
    },
    "candidate_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "receipt_location", "current_binding", "self_binding_forbidden"],
      "properties": {
        "mode": {"const": "external_post_commit_receipt_required"},
        "receipt_location": {"const": "external_result_pack"},
        "current_binding": {"const": false},
        "self_binding_forbidden": {"const": true}
      }
    },
    "authority_digest": {"type": "string", "minLength": 1},
    "source_snapshot": {
      "type": ["object", "null"],
      "properties": {
        "library_file_id": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "required": ["library_file_id", "sha256"],
      "additionalProperties": false
    },
    "product_lanes": {
      "type": "object",
      "additionalProperties": {
        "enum": [
          "NOT_RUN",
          "BLOCKED",
          "FAILED",
          "PASSED_FOCUSED",
          "PASSED_INTEGRATED",
          "PASSED_INDEPENDENT"
        ]
      }
    },
    "open_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "priority", "summary", "owner", "tracking_ref", "acceptance_test", "target"],
        "properties": {
          "id": {"type": "string"},
          "priority": {"enum": ["P0", "P1", "P2"]},
          "summary": {"type": "string"},
          "owner": {"type": "string"},
          "tracking_ref": {"type": "string", "pattern": "^deeplus-action:[A-Za-z0-9._-]+$"},
          "acceptance_test": {"type": "string", "minLength": 1},
          "target": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "required_next_reviews": {
      "type": "array",
      "items": {"type": "string"}
    },
    "previous_pointer": {"type": ["string", "null"]}
  }
}
